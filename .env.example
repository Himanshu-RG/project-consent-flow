# Database Configuration
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_USER=consentmap_user
POSTGRES_PASSWORD=consentmap_pass
POSTGRES_DB=consentmap_db

# Database Connection URL (for application)
DATABASE_URL=postgresql://consentmap_user:consentmap_pass@localhost:5433/consentmap_db

# Application Configuration
NODE_ENV=development
PORT=3000
