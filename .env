# Database Configuration
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_USER=consentmap
POSTGRES_PASSWORD=consentmap_dev_password
POSTGRES_DB=consentmap_db

# Database Connection URL (for application)
DATABASE_URL=postgresql://consentmap:consentmap_dev_password@localhost:5433/consentmap_db

# Application Configuration
NODE_ENV=development
PORT=3000
