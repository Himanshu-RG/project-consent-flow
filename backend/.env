# Environment Configuration for FastAPI Backend

# Database Configuration
DATABASE_URL=postgresql://consentmap_user:consentmap_pass@localhost:5433/consentmap_db

# JWT Secret Key (change this in production!)
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
APP_NAME=ConsentMap API
APP_VERSION=1.0.0
DEBUG=True

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# File Upload Settings
# (File upload paths and limits are configured in config.py)

# Server Settings
HOST=0.0.0.0
PORT=8000
